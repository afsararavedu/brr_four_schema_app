# /etc/brr/brr-api.env
#
# Environment for the brr-api systemd service.
# Permissions: chown root:root, chmod 600 -- this file holds DB creds and
# the session-signing secret.

# ---- Required ----------------------------------------------------------

# Set to "http" (not "production") so the session cookie does NOT get the
# Secure flag — required when the site runs on plain HTTP without TLS.
# Change to "production" only if you add HTTPS (SSL termination) in front.
NODE_ENV=http

# Loopback port that nginx forwards /api/* to. Match this in nginx.conf.
PORT=8080

# Postgres connection string for RDS (or any reachable Postgres).
# Format: postgres://USER:PASS@HOST:5432/DBNAME
DATABASE_URL=postgres://brr:CHANGE_ME@brr-db.xxxxxx.ap-south-2.rds.amazonaws.com:5432/postgres

# PostgreSQL schema to use (search_path). Each tenant/shop gets its own schema.
# Available schemas: balaji_schema | jyothi_schema | padma_schema | shop4_schema
# Defaults to "public" when not set.
DB_SCHEMA=balaji_schema

# Long random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
# Required when NODE_ENV=production. Optional for other values but STRONGLY
# recommended — without it a hardcoded fallback is used.
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING

# ---- Optional ----------------------------------------------------------

# Set to "false" when running without HTTPS so session cookies work over HTTP.
# This is the default behaviour when NODE_ENV != "production".
# COOKIE_SECURE=false

# One-time bootstrap password for the very first admin user. Only used
# when the users table is empty. The account is created with
# mustResetPassword=true, so the operator must set a real password on
# first login. If unset, a random password is generated and printed once
# to the journal -- check `journalctl -u brr-api` right after first boot.
# Must be at least 8 characters.
# ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_AT_LEAST_8_CHARS

# Pino log level: trace | debug | info | warn | error | fatal. Default: info.
# LOG_LEVEL=info
