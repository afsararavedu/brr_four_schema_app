# /etc/nginx/conf.d/brr.conf
#
# HTTP-only reverse-proxy + static-file config for BRR Liquor Soft.
#
# Layout assumed by this file:
#   /var/www/brr-web/     -> contents of release/web (the vite static build)
#   127.0.0.1:8080        -> the brr-api systemd service (api-server)
#
# After editing: `sudo nginx -t && sudo systemctl reload nginx`.

server {
    listen 80;
    listen [::]:80;
    server_name _;

    # Allow large Excel/PDF uploads (multer + xlsx routes accept up to 10mb).
    client_max_body_size 16m;

    # ---- API: forward /api/* to the node service on loopback ----
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        proxy_pass_request_headers on;
        proxy_redirect off;

        # Long-running requests (PDF/Excel parsing of large files).
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # ---- Static frontend with SPA fallback ----
    root /var/www/brr-web;
    index index.html;

    # Fingerprinted Vite assets — cache aggressively.
    location /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # The HTML shell must NOT be cached.
    location = /index.html {
        add_header Cache-Control "no-store";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
