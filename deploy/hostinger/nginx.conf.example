# /etc/nginx/conf.d/brr.conf
#
# nginx config for BRR Liquor Soft on Hostinger KVM 2 VPS.
# Supports both HTTP-only and HTTPS (Let's Encrypt / Certbot) setups.
#
# Layout assumed by this file:
#   /var/www/brr-web/     -> contents of release/web/ (Vite static build)
#   127.0.0.1:8080        -> brr-api systemd service (single tenant)
#
# After editing: `sudo nginx -t && sudo systemctl reload nginx`


# ── OPTION A: HTTP only (no SSL yet) ────────────────────────────────────────
# Use this block while you don't have a domain / certificate yet.
# Comment it out and use OPTION B once you have HTTPS working.

# server {
#     listen 80;
#     listen [::]:80;
#     server_name _;                  # Replace _ with your domain when ready
#     client_max_body_size 16m;
#
#     location /api/ {
#         proxy_pass http://127.0.0.1:8080;
#         proxy_http_version 1.1;
#         proxy_set_header Host              $host;
#         proxy_set_header X-Real-IP         $remote_addr;
#         proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#         proxy_read_timeout 120s;
#         proxy_send_timeout 120s;
#     }
#
#     root /var/www/brr-web;
#     index index.html;
#
#     location /assets/ {
#         try_files $uri =404;
#         access_log off;
#         expires 1y;
#         add_header Cache-Control "public, immutable";
#     }
#     location = /index.html { add_header Cache-Control "no-store"; try_files $uri =404; }
#     location / { try_files $uri $uri/ /index.html; }
# }


# ── OPTION B: HTTPS with Let's Encrypt (Certbot) ────────────────────────────
# Prerequisites:
#   1. DNS: point yourdomain.com (and www.yourdomain.com) at your VPS IP
#   2. Run:  apt install -y certbot python3-certbot-nginx
#            certbot --nginx -d yourdomain.com -d www.yourdomain.com
#   Certbot will fill in the ssl_certificate paths and add the redirect below
#   automatically. This file shows what the result looks like.

# Redirect all HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    # Allow certbot ACME challenge through
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Everything else → HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name yourdomain.com www.yourdomain.com;

    # Certbot fills these in automatically (paths may differ slightly).
    ssl_certificate     /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 16m;

    # ---- API: forward /api/* to the Node.js service on loopback ----
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host  $host;

        proxy_pass_request_headers on;
        proxy_redirect off;

        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # ---- Static frontend with SPA fallback ----
    root /var/www/brr-web;
    index index.html;

    location /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location = /index.html {
        add_header Cache-Control "no-store";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}


# ── MULTI-TENANT SETUP (HTTPS) ───────────────────────────────────────────────
# Uncomment and adapt when running multiple shops on separate subdomains.
# Run certbot for each subdomain:
#   certbot --nginx -d balaji.yourdomain.com -d jyothi.yourdomain.com ...
