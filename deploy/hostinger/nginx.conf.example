#         proxy_send_timeout 120s;
#     }
#     root /var/www/brr-web;
#     index index.html;
#     location /assets/ { try_files $uri =404; access_log off; expires 1y; add_header Cache-Control "public, immutable"; }
#     location = /index.html { add_header Cache-Control "no-store"; try_files $uri =404; }
#     location / { try_files $uri $uri/ /index.html; }
