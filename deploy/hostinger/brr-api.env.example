# /etc/brr/brr-api.env
#
# Environment for the brr-api systemd service on Hostinger KVM 2 VPS.
# Permissions: chown root:root, chmod 600 -- this file holds DB creds and
# the session-signing secret.
#
# Copy this file:
#   sudo cp deploy/hostinger/brr-api.env.example /etc/brr/brr-api.env
#   sudo nano /etc/brr/brr-api.env   # fill in your values
#   sudo chown root:root /etc/brr/brr-api.env
#   sudo chmod 600 /etc/brr/brr-api.env

# ---- Required ----------------------------------------------------------

# "http"       → plain HTTP (no SSL). Session cookies work without HTTPS.
# "production" → HTTPS (Let's Encrypt). Enables trust proxy + Secure cookies.
#                Change to this AFTER certbot is installed and working.
NODE_ENV=http

# Loopback port that nginx forwards /api/* to. Match this in nginx.conf.
PORT=8080

# Supabase Transaction Pooler URL (port 6543) — used for all runtime queries.
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
# Select "Transaction" mode and copy the URI.
# The ?pgbouncer=true flag disables prepared statements (required for PgBouncer
# transaction mode — without it you will get "prepared statement already exists" errors).
#
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.CHANGE_ME:CHANGE_ME@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Direct Connection URL (port 5432) — used ONLY for schema bootstrap
# (CREATE SCHEMA IF NOT EXISTS) at startup. PgBouncer (transaction pooler)
# blocks DDL, so we use the direct URL for this one operation only.
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
# Select "Direct connection" (Session mode or Direct) and copy the URI.
#
# Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_DATABASE_URL=postgresql://postgres.CHANGE_ME:CHANGE_ME@db.CHANGE_ME.supabase.co:5432/postgres

# PostgreSQL schema to use (search_path). Each tenant/shop gets its own schema.
# Available schemas: balaji_schema | jyothi_schema | padma_schema | shop4_schema
# Defaults to "public" when not set.
DB_SCHEMA=balaji_schema

# Long random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
# Required when NODE_ENV=production. Optional for other values but STRONGLY
# recommended — without it a hardcoded fallback is used.
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING

# ---- Optional ----------------------------------------------------------

# Allowed CORS origins for the API server.
# Set to your frontend domain(s), comma-separated.
# Leave unset to mirror the request origin (fine for same-host setups).
# Example: CORS_ORIGIN=http://yourdomain.com,https://yourdomain.com
# CORS_ORIGIN=http://yourdomain.com

# Set to "false" when running without HTTPS so session cookies work over HTTP.
# This is the default behaviour when NODE_ENV != "production".
# COOKIE_SECURE=false

# One-time bootstrap password for the very first admin user. Only used
# when the users table is empty. The account is created with
# mustResetPassword=true, so the operator must set a real password on
# first login. If unset, a random password is generated and printed once
# to the journal -- check `journalctl -u brr-api` right after first boot.
# Must be at least 8 characters.
# ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_AT_LEAST_8_CHARS

# Pino log level: trace | debug | info | warn | error | fatal. Default: info.
# LOG_LEVEL=info
