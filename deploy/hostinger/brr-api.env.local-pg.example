# /etc/brr/brr-api.env
#
# Environment for the brr-api systemd service on Hostinger KVM 2 VPS
# using a LOCAL PostgreSQL installation (no Supabase / no cloud DB).
#
# Permissions: chown root:root, chmod 600 -- this file holds DB creds and
# the session-signing secret.
#
# Copy this file:
#   sudo cp deploy/hostinger/brr-api.env.local-pg.example /etc/brr/brr-api.env
#   sudo nano /etc/brr/brr-api.env   # fill in your values
#   sudo chown root:root /etc/brr/brr-api.env
#   sudo chmod 600 /etc/brr/brr-api.env

# ---- Required ----------------------------------------------------------

# "http"       → plain HTTP (no SSL). Session cookies work without HTTPS.
# "production" → HTTPS (Let's Encrypt). Enables trust proxy + Secure cookies.
#                Change to this AFTER certbot is installed and working.
NODE_ENV=http

# Loopback port that nginx forwards /api/* to. Match this in nginx.conf.
PORT=8080

# Local PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@localhost:5432/DATABASE
# Replace brr, CHANGE_ME, and brr_db with your actual values.
DATABASE_URL=postgresql://brr:CHANGE_ME@localhost:5432/brr_db

# DIRECT_DATABASE_URL is NOT needed for local PostgreSQL — it falls back
# to DATABASE_URL automatically when unset.

# PostgreSQL schema to use (search_path). Each tenant/shop gets its own schema.
# Available schemas: balaji_schema | jyothi_schema | padma_schema | mallanna_schema
# Defaults to "public" when not set.
DB_SCHEMA=balaji_schema

# Long random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING

# ---- Optional ----------------------------------------------------------

# Allowed CORS origins for the API server.
# Set to your frontend domain(s), comma-separated.
# Leave unset to mirror the request origin (fine for same-host setups).
# CORS_ORIGIN=http://yourdomain.com

# One-time bootstrap password for the very first admin user. Only used
# when the users table is empty. The account is created with
# mustResetPassword=true, so the operator must set a real password on
# first login. If unset, a random password is generated and printed once
# to the journal -- check `journalctl -u brr-api` right after first boot.
# Must be at least 8 characters.
# ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_AT_LEAST_8_CHARS

# Pino log level: trace | debug | info | warn | error | fatal. Default: info.
# LOG_LEVEL=info
